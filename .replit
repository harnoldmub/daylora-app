modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["ghostscript", "glib", "nss", "nspr", "at-spi2-atk", "cups", "libdrm", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "xorg.libX11", "xorg.libxshmfence", "mesa", "expat", "alsa-lib", "pango", "cairo", "dbus", "atk", "chromium"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]
publicDir = "dist"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5174
externalPort = 3000

[[ports]]
localPort = 5904
externalPort = 3003

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "SESSION_STORE=db npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
integrations = ["javascript_database:1.0.0", "javascript_log_in_with_replit:1.0.0", "resend:1.0.0", "stripe:2.0.0"]
expertMode = true

[userenv]

[userenv.production]
APP_BASE_URL = "https://daylora.app"
STRIPE_PRICE_SUBSCRIPTION = "price_1T5Bd4CdXaBy714IWQmjYwiL"
STRIPE_PRICE_LIFETIME = "price_1T5BdcCdXaBy714IKzwNf5da"

[userenv.development]
APP_BASE_URL = "https://daylora.app"
STRIPE_PRICE_SUBSCRIPTION = "price_1T4SrfCsy2ZICqoPYBxhtxNG"
STRIPE_PRICE_LIFETIME = "price_1T2F8zCsy2ZICqoPdsEp5pAD"

[userenv.shared]
APP_NAME = "Daylora"
APP_DOMAIN = "daylora.app"
SUPER_ADMIN_EMAIL = "admin@daylora.app"
