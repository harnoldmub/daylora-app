{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:app",
    "dev:api": "PORT=3000 NODE_ENV=development tsx apps/api/index.ts",
    "dev:app": "npm --prefix apps/app run dev",
    "dev:marketing": "npm --prefix apps/marketing run dev",
    "build": "npm --prefix apps/app run build && mkdir -p dist && cp -r apps/app/dist/public dist/public && node -e \"require('esbuild').buildSync({entryPoints:['apps/api/index.ts'],bundle:true,platform:'node',format:'esm',outfile:'dist/index.js',external:['argon2','bcryptjs','better-sqlite3','stripe-replit-sync','@neondatabase/serverless','pg-native','bufferutil','utf-8-validate'],banner:{js:\\\"import{createRequire}from'module';const require=createRequire(import.meta.url);\\\"},packages:'external'})\"",
    "start": "NODE_ENV=production node dist/index.js",
    "start:api": "NODE_ENV=production node dist/index.js",
    "check": "npm --prefix apps/app run check && npm --prefix apps/marketing run check && tsc -p apps/api/tsconfig.json",
    "db:push": "drizzle-kit push",
    "seed:test-user": "tsx scripts/create-test-user.ts",
    "test:smoke": "tsx scripts/smoke.ts",
    "test": "vitest run --config tests/vitest.config.unit.ts && vitest run --config tests/vitest.config.api.ts",
    "test:unit": "vitest run --config tests/vitest.config.unit.ts",
    "test:unit:watch": "vitest --config tests/vitest.config.unit.ts",
    "test:api": "vitest run --config tests/vitest.config.api.ts",
    "test:api:watch": "vitest --config tests/vitest.config.api.ts",
    "test:component": "vitest run --config tests/vitest.config.component.ts",
    "test:coverage": "vitest run --config tests/vitest.config.unit.ts --coverage && vitest run --config tests/vitest.config.api.ts --coverage",
    "test:all": "npm run test:unit && npm run test:api && npm run test:component",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config tests/e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "@neondatabase/serverless": "^0.10.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/helmet": "^0.0.48",
    "@types/memoizee": "^0.4.12",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "argon2": "^0.41.1",
    "bcryptjs": "^3.0.2",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "jsdom": "^28.1.0",
    "memoizee": "^0.4.17",
    "memorystore": "^1.6.7",
    "nodemailer": "^7.0.11",
    "openid-client": "^6.8.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "resend": "^6.1.3",
    "stripe": "^20.0.0",
    "stripe-replit-sync": "^1.0.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "20.16.11",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
