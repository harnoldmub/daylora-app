{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:app",
    "dev:api": "PORT=3000 NODE_ENV=development tsx apps/api/index.ts",
    "dev:app": "npm --prefix apps/app run dev",
    "dev:marketing": "npm --prefix apps/marketing run dev",
    "start:api": "NODE_ENV=production node dist/index.js",
    "check": "npm --prefix apps/app run check && npm --prefix apps/marketing run check && tsc -p apps/api/tsconfig.json",
    "db:push": "drizzle-kit push",
    "seed:test-user": "tsx scripts/create-test-user.ts",
    "test:smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "@neondatabase/serverless": "^0.10.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/helmet": "^0.0.48",
    "@types/memoizee": "^0.4.12",
    "@types/nodemailer": "^7.0.4",
    "argon2": "^0.41.1",
    "bcryptjs": "^3.0.2",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "memoizee": "^0.4.17",
    "memorystore": "^1.6.7",
    "nodemailer": "^7.0.11",
    "openid-client": "^6.8.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "resend": "^6.1.3",
    "stripe": "^20.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "20.16.11",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
